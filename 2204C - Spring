void solve(int iTest){
    cin >> a >> b >> c >> m;
    ll ansA = 0, ansB = 0, ansC = 0;
    ll andAB = a*b/__gcd(a, b);
    ll andBC = b*c/__gcd(b, c);
    ll andCA = c*a/__gcd(c, a);
    ll andABC = andAB*c/__gcd(andAB, c);

    ansA = (m/a)*6 - m/andAB*6 + m/andAB*3
            -m/andCA*6 + m/andCA*3 + m/andABC*2;

    ansB = (m/b)*6 - m/andAB*6 + m/andAB*3
            -m/andBC*6 + m/andBC*3 + m/andABC*2;

    ansC = (m/c)*6 - m/andCA*6 + m/andCA*3
            -m/andBC*6 + m/andBC*3 + m/andABC*2;
    cout << ansA << ' ' << ansB << ' ' << ansC << el;
}

signed main(){
    ios_base::sync_with_stdio(0);
