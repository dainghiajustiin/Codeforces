#include<bits/stdc++.h>
using namespace std;

const int N = (int) 2e5 + 7;

int n;
int a[N];
int pre[N], suf[N];

void Solve(){
    cin >> n;

    for(int i = 0; i < n; i++) cin >> a[i], pre[i] = suf[i] = 0;

    for(int i = 1; i < n; i++){
        pre[i] = pre[i - 1] + (a[i] >= a[i - 1]);
    }

    for(int i = n - 2; i >= 0; i--){
        suf[i] = suf[i + 1] + (a[i] >= a[i + 1]);
    }

    int ans = suf[0];

    for(int i = 1; i < n; i++){
        ans = min(ans, pre[i - 1] + suf[i] + 1);
    }

    cout << ans << '\n';
}

int main(){
    ios_base::sync_with_stdio(0);
    cin.tie(0);

