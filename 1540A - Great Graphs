const int MAXN = (int) 1e5 + 7;

ll d[MAXN], pre[MAXN];

///

void init(){

}

void solve(int iTest){
    ll n, S = 0;
    cin >> n;
    for(int i = 1; i <= n; i++) cin >> d[i];
    sort(d + 1, d + 1 + n);
    for(int i = 1; i <= n; i++) S += d[i] - d[i - 1], pre[i] = pre[i - 1] + d[i];
    for(int i = 1; i <= n; i++) S = S + (pre[i - 1] - (i-1)*d[i]);
    cout << S << el;
}

