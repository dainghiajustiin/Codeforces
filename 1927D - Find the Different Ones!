/// code
const int maxn = (int) 2e5 + 3;
int a[maxn];
int lp[maxn];
int n, q;

void solve(){
    cin >> n;
    for(int i = 1; i <= n; i++) cin >> a[i];
    lp[1] = -1;
    for(int i = 2; i <= n; i++){
        lp[i] = lp[i - 1];
        if(a[i] != a[i - 1]) lp[i] = i - 1;
    }
    cin >> q;
    while(q--){
        int l, r; cin >> l >> r;
        if(lp[r] < l) cout << -1 << ' ' << -1 << el;
        else cout << lp[r] << ' ' << r << el;
    }
    cout << el;
}

signed main(){
    ios_base::sync_with_stdio(0);
    cin.tie(0);

