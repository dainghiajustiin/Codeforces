#include<bits/stdc++.h>
using namespace std;

int main(){
    ios_base::sync_with_stdio(0);
    cin.tie(0); cout.tie(0);

    int nTest; cin >> nTest;

    while(nTest--){
        int x, y;
        cin >> x >> y;
        if (x - 1 == y)
        {
            cout << -1 << '\n';
            continue;
        }
        if(x > y && y == 1){
            cout << -1 << '\n';
            continue;
        }

        if(x < y) cout << 2 << '\n';
        else if(x == y) cout << -1 << '\n';
        else cout << 3 << '\n';
    }

    return 0;
}
