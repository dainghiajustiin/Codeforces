#include<bits/stdc++.h>
using namespace std;

#define ll long long
#define Mp make_pair
#define fi first
#define se second
#define pb push_back
#define el '\n'
#define all(x) x.begin(), x.end()

const int MOD = (int) 1e9 + 7;
const ll inf = (ll) 1e18 + 7;
using pii = pair<int,int>;

/// code
const int maxn = (int) 2e5 + 3;
vector<int> vec[maxn];
int a[maxn];
int n, c;

ll dp[2][maxn];

void dfs(int u, int p){
    vector<ll> val[2];
    val[0].resize(vec[u].size() + 1);
    val[1].resize(vec[u].size() + 1);

    val[0][0] = 0;
    val[1][0] = a[u];

    int dem = 0;
    for(int v:vec[u]){
        if(v == p) continue;
        dfs(v, u);
        dem++;

        for(int u_ = 0; u_ < 2; u_++){
            for(int v_ = 0; v_ < 2; v_++){
                ll res = val[u_][dem - 1] + dp[v_][v] - (u_ && v_ ? 2*c : 0);
                val[u_][dem] = max(val[u_][dem], res);
            }
        }
    }

    dp[0][u] = val[0][dem];
    dp[1][u] = val[1][dem];
}

void solve(){
    cin >> n >> c;
    for(int i = 1; i <= n; i++) cin >> a[i];

    for(int i = 1; i < n; i++){
        int u, v; cin >> u >> v;
        vec[u].pb(v);
        vec[v].pb(u);
    }

    dfs(1, 0);

    ll ans = max(dp[0][1], dp[1][1]);
    cout << ans << el;

    for(int i = 1; i <= n; i++) vec[i].clear();
}

signed main(){
    ios_base::sync_with_stdio(0);
    cin.tie(0);

//    #define task ""
//    freopen(task".inp", "r", stdin);
//    freopen(task".out", "w", stdout);

    int t; cin >> t;
    while(t--) solve();

    return 0;
}
