    f[1] = 1;
    dp[1] = 0;

    for(int i = 2; i <= (int) 1e5; i++){
        f[i] = f[i - 1] * i % MOD;
        dp[i] = (dp[i - 1] + 2 * (i - 1)) % MOD;
    }

    int t; cin >> t;
    while(t--){
        int n; cin >> n;
        int ans = dp[n] * f[n] % MOD;
        cout << ans << el;
    }

