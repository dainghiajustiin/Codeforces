#define submit(x) if( fopen(x".inp", "r") ){ freopen(x".inp", "r", stdin); freopen(x".out", "w", stdout); }
#define all(x) x.begin(), x.end()

template<class X, class Y> void maximize(X &a, const Y &b) { a = (a < b) ? b : a; }
template<class X, class Y> void minimize(X &a, const Y &b) { a = (a > b) ? b : a; }

const int MOD = 1e9 + 7, inf = 1e18;
using ll = long long;
using ull = unsigned long long;
using pii = pair<int,int>;

const int maxn = 2e5 + 7;
int n, m, k;
string s;

void solve(){
    cin >> n >> m >> k;
    cin >> s;
    s = 'L' + s + 'L';

    for(int i = 0; i <= n + 1;){
        if(i >= n + 1) break;

        int ii = 0, iii = 0;

        if(s[i] == 'L'){
            for(int j = i + 1; j <= i + m && j <= n + 1; j++){
                if(s[j] == 'L') ii = j;
                if(s[j] == 'W') iii = j;
            }
        }
        else if(s[i] == 'W'){
            for(int j = i + 1; k && j <= n + 1; j++){
                if(s[j] == 'C'){
                    cout << "NO" << el;
                    return;
                }
                k--;
                if(s[j] == 'L'){
                    ii = j;
                    break;
                }
            }
        }

        if(ii > i) i = ii;
        else if(iii > i) i = iii;
        else{
            cout << "NO" << el;
            return;
        }
    }

    cout << "YES" << el;
}

signed main(){
    ios_base::sync_with_stdio(0);
    cin.tie(0);

    submit("")

    int t; cin >> t;
    while(t--) solve();

    return 0;
}
