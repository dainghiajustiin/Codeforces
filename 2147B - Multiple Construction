#include<bits/stdc++.h>
using namespace std;

const int maxN = (int) 5e5 + 7;

int a[maxN];

void solve()
{
    int n; cin >> n;

    for(int i = 1; i <= 2*n; i++) a[i] = 0;

    int maxEven = n;
    int maxOdd = n;
    if(n % 2 == 1) maxEven--;
    else maxOdd--;

    int pos = 2*n;
    int lowpos = pos - maxEven - 1;

    while(maxEven > 0){
        a[pos] = maxEven;
        a[pos - maxEven] = maxEven;
        maxEven -= 2;
        pos--;
    }

    if(maxOdd != 1){
        a[pos] = maxOdd;
        a[pos - maxOdd] = maxOdd;
        maxOdd -= 2;
    }
    while(maxOdd > 1){
        a[lowpos] = maxOdd;
        a[lowpos - maxOdd] = maxOdd;
        maxOdd -= 2;
        lowpos--;
    }

    for(int i = 1; i <= 2*n; i++){
        if(a[i] == 0) a[i] = 1;
    }

    for(int i = 1; i <= 2*n; i++) cout << a[i] << ' ';
}

int main(){
    ios_base::sync_with_stdio(0);
    cin.tie(0); cout.tie(0);

    int nTest; cin >> nTest;

    while(nTest--)
    {
        solve();
        cout << '\n';
    }

    return 0;
}
