/// code
const int maxn = 1009;
int a[maxn];
int b[maxn];
int c[maxn];

void solve(){
    int n; cin >> n;
    for(int i = 1; i <= n; i++) cin >> a[i];

    sort(a + 1, a + 1 + n, __greater());
    sort(a + 2, a + 1 + n);

    b[1] = c[1] = a[1];

    for(int i = 2; i <= n; i++){
        b[i] = min(b[i - 1], a[i]);
        c[i] = max(c[i - 1], a[i]);
    }

    ll ans = 0;
    for(int i = 1; i <= n; i++) ans += (c[i] - b[i]);

    cout << ans << el;
}

