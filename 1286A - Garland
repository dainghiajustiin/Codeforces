#include<bits/stdc++.h>
using namespace std;

int dp[100][100][2], a, n;

void Solve(){
    cin >> n;

    for (int i = 0; i < n; ++i){
        for (int j = 0; j < n; ++j){
            dp[i][j][0] = dp[i][j][1] = 2e9;
        }
    }

    for (int i = 0; i < n; ++i){
        cin >> a;
        if (a == 0){
            if (i == 0){
                dp[i][0][0] = 0;
                dp[i][1][1] = 0;
                continue;
            }

            for (int j = 0; j <= (n + 1) / 2; ++j){
                dp[i][j][0] = min(dp[i - 1][j][0], dp[i - 1][j][1] + 1);
                if (j > 0){
                    dp[i][j][1] = min(dp[i - 1][j - 1][0] + 1, dp[i - 1][j - 1][1]);
                }
            }
        }
        else{
            if (i == 0){
                dp[i][a & 1][a & 1] = 0;
                continue;
            }
            for (int j = a & 1; j <= (n + 1) / 2; ++j){
                dp[i][j][a & 1] = min(dp[i - 1][j - (a & 1)][0] + (a & 1), dp[i - 1][j - (a & 1)][1] + !(a & 1));
            }
        }
    }

    cout << min(dp[n - 1][(n + 1) / 2][0], dp[n - 1][(n + 1) / 2][1]);
}

int main(){
    ios_base::sync_with_stdio(0);
    cin.tie(0);

