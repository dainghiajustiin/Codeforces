#include<bits/stdc++.h>
#define ll long long
using namespace std;

const int MAXN = (int) 1e5 + 7;
const int MOD = (int) 1e9 + 7;
int n, k, dp[2][MAXN];

signed main(){
    ios_base::sync_with_stdio(0);
    cin.tie(0), cout.tie(0);

    cin >> n >> k;
    for(int i = 1; i <= n; i++) dp[0][i] = 1;

    int cur = 1, pre = 0;
    for(int i = 2; i <= k; i++){
        for(int j = 1; j <= n; j++) dp[cur][j] = 0;
        for(int j = 1; j <= n; j++){
            for(int valk = j; valk <= n; valk += j) (dp[cur][valk] += dp[pre][j]) %= MOD;
        }
        pre = 1 - pre;
        cur = 1 - cur;
    }

    int ans = 0;
    for(int i = 1; i <= n; i++) ans = (ans + dp[pre][i]) % MOD;
    cout << ans;

    return 0;
}
