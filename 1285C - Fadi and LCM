void solve(int iTest){
    ll n; cin >> n;
    ll ans = n;
    ll x = 1, y = n;
    for(ll a = 1; a*a <= n; a++){
        ll gcd = __gcd(a, n);
        if(gcd == 1) continue;
        ll b = n/gcd;
        if(a*b/__gcd(a, b) == n){
            if(ans > max(a, b)){
                ans = max(a, b);
                x = min(a, b);
                y = max(a, b);
            }
        }
    }
    cout << x << ' ' << y;
}

