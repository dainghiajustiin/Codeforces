#include<bits/stdc++.h>
using namespace std;

signed main(){
    ios_base::sync_with_stdio(0);
    cin.tie(0);

    int nTest;
    cin >> nTest;
    while(nTest--){
        int n;
        string s;
        cin >> n >> s;
        int a = 0, b = 0;
        for(auto elm:s){
            if(elm == '(') a++;
            else b++;
        }
        if(a != b) cout << "NO\n";
        else cout << "YES\n";
    }

    return 0;
}
