#include<bits/stdc++.h>
#define ll long long 
using namespace std;

const int MAXN = (int) 1e5 + 7;

ll n, a[MAXN], b[MAXN], dp[2][MAXN];

signed main(){
    ios_base::sync_with_stdio(0);
    cin.tie(0), cout.tie(0);

    cin >> n;
    for(int i = 1; i <= n; i++) cin >> a[i];
    for(int i = 1; i <= n; i++) cin >> b[i];

    dp[0][1] = a[1];
    dp[1][1] = b[1];
    dp[0][2] = dp[1][1] + a[2];
    dp[1][2] = dp[0][1] + b[2];

    for(int i = 3; i <= n; i++){
        dp[0][i] = max(dp[1][i-2], dp[1][i-1]) + a[i];
        dp[1][i] = max(dp[0][i-2], dp[0][i-1]) + b[i];
    }

    cout << max(dp[0][n], dp[1][n]);

    return 0;
}
