#include<bits/stdc++.h>
using namespace std;

const int N = (int) 2e5 + 7;

int nSize, k;
int x[N];
int L[N], R[N];

void solve(){
    cin >> nSize >> k;
    for(int i = 1; i <= nSize; i++) cin >> x[i];
    for(int i = 1; i <= nSize; i++){
        int y; cin >> y;
    }

    sort(x + 1, x + 1 + nSize);
    int j = 1;

    for(int i = 1; i <= nSize; i++){
        while(x[i] - x[j] > k) j++;
        L[i] = (i - j + 1);
    }

    for(int i = 2; i <= nSize; i++){
        L[i] = max(L[i], L[i - 1]);
    }

    j = nSize;
    for(int i = nSize; i > 0; i--){
        while(x[j] - x[i] > k) j--;
        R[i] = (j - i + 1);
    }

    for(int i = nSize - 1; i > 0; i--){
        R[i] = max(R[i], R[i + 1]);
    }

    int ans = 1;
    for(int i = 1; i < nSize; i++){
        ans = max(ans, L[i] + R[i + 1]);
    }
    cout << ans << '\n';
}

int main(){
    ios_base::sync_with_stdio(0);
    cin.tie(0);

//    #define TASK ""
