///
const int MAXN = (int) 2e5 + 7;

int n, m, a[MAXN];
struct dataa{
    int value, realCnt, fakeCnt;
} u[MAXN], v[MAXN];

///

bool cmp(dataa &x, dataa &y){
    return x.value > y.value;
}

bool check(int mid){
    for(int i = 1; i <= n; i++) v[i] = u[i];
    for(int i = 1; i <= n; i++){
        if(v[i].value <= mid) return true;
        if(i == n) return false;
        int dist = v[i].value - mid;
        int out = (dist + 1)/2;
        int nxt = min(out, v[i].fakeCnt);

        dist -= nxt*2;
        v[i].value -= nxt*2;
        v[i].fakeCnt -= nxt;
        v[i+1].value += nxt*2;
        v[i+1].fakeCnt += nxt;

        if(dist > 0){
            out = dist;
            nxt = min(out, v[i].realCnt);

            dist -= nxt;
            v[i].value -= nxt;
            v[i].realCnt -= nxt;
            v[i+1].value += nxt*2;
            v[i+1].fakeCnt += nxt;
        }

        if(dist > 0) return false;
    }
    return true;
}

void init(){

}

void solve(int iTest){
    cin >> n >> m;
    for(int i = 1; i <= n; i++){
        u[i].value = 0;
        u[i].realCnt = 0;
        u[i].fakeCnt = 0;
    }

    for(int i = 1; i <= m; i++){
        cin >> a[i];
        u[a[i]].value += 1;
        u[a[i]].realCnt += 1;
    }
    sort(u + 1, u + 1 + n, cmp);

    int low = 1, high = 2*m, ans = 2*m;
    while(low <= high){
        int mid = (low + high) >> 1;
        if(check(mid)){
            ans = mid;
            high = mid - 1;
        }
        else low = mid + 1;
    }
    cout << ans << el;
}

signed main(){
    ios_base::sync_with_stdio(0);
    cin.tie(0);

    #define task "buon"
    if(fopen(task".inp", "r")){
        freopen(task".inp", "r", stdin);
        freopen(task".out", "w", stdout);
    }

    init();

    int nTest = 1;
    cin >> nTest;

    for(int iTest = 1; iTest <= nTest; iTest++){
        solve(iTest);
    }

    return 0;
}

