void BFS(int i){
    priority_queue<pii, vector<pii>, greater<pii>> pq;
    pq.push({0, i});
    while(!pq.empty()){
        pii f = pq.top();
        int cnt = f.fi;
        int u = f.se;
        pq.pop();
        if(u > 0 && dp[u-1] > dp[u] + 1){
            dp[u-1] = cnt + 1;
            pq.push({cnt + 1, u-1});
        }
        if(2*u >= m) dp[m] = min(dp[m], cnt + 1 + (2*u - m));
        else if(dp[2*u] > dp[u] + 1){
            dp[2*u] = cnt + 1;
            pq.push({cnt + 1, 2*u});
        }
    }
}

