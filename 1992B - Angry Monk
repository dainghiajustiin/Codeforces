#include<bits/stdc++.h>
using namespace std;

#define int long long
#define el '\n'
#define fi first
#define se second
#define pb push_back
#define submit(x) if( fopen(x".inp", "r") ){ freopen(x".inp", "r", stdin); freopen(x".out", "w", stdout); }
#define all(x) x.begin(), x.end()

template<class X, class Y> void maximize(X &a, const Y &b) { a = (a < b) ? b : a; }
template<class X, class Y> void minimize(X &a, const Y &b) { a = (a > b) ? b : a; }

const int MOD = 1e9 + 7, inf = 1e18;
using ll = long long;
using ull = unsigned long long;
using pii = pair<int,int>;

const int maxn = 2e5 + 7;
int a[maxn];
int n, k;

void solve(){
   cin >> n >> k;
   int ma = 0, s = 0;
   for(int i = 1; i <= k; i++){
        cin >> a[i];
        ma = max(ma, a[i]);
   }

   if(ma == 1){
        cout << n - 1 << el;
        return;
   }

   for(int i = 1; i <= k; i++){
        if(a[i] >= 2) s += a[i] - 1;
   }

   s -= ma - 1;

    cout << s + n - ma << el;
}

signed main(){
    ios_base::sync_with_stdio(0);
    cin.tie(0);

    submit("")

    int t; cin >> t;
    while(t--) solve();

    return 0;
}
