const int MAXN = (int) 2e5 + 7;

int BIT[MAXN*4];
int a[MAXN], b[MAXN], n;
vector<int> v;

///

void add(int idx){
    for(; idx < MAXN*4; idx += idx&-idx) BIT[idx]++;
}

int get(int idx){
    int res = 0;
    for(; idx > 0; idx -= idx&-idx) res += BIT[idx];
    return res;
}

void init(){

}

void solve(int iTest){
    cin >> n;
    for(int i = 1; i <= n; i++) cin >> a[i];
    for(int i = 1; i <= n; i++) cin >> b[i];
    for(int i = 1; i <= n; i++){
        v.pb(a[i] - b[i]);
        v.pb(b[i] - a[i]);
    }
    sort(all(v));
    v.resize(unique(all(v)) - v.begin());
    ll ans = 0;
    for(int i = 1; i <= n; i++){
        int pos = lower_bound(all(v), a[i] - b[i]) - v.begin() + 1;
        ans += get(pos-1);
        pos = lower_bound(all(v), b[i] - a[i]) - v.begin() + 1;
        add(pos);
    }
    cout << ans;
}

