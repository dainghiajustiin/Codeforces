#include<bits/stdc++.h>
using namespace std;

#define int long long
#define el '\n'
#define fi first
#define se second
#define pb push_back
#define submit(x) if( fopen(x".inp", "r") ){ freopen(x".inp", "r", stdin); freopen(x".out", "w", stdout); }
#define all(x) x.begin(), x.end()

template<class X, class Y> void maximize(X &a, const Y &b) { a = (a < b) ? b : a; }
template<class X, class Y> void minimize(X &a, const Y &b) { a = (a > b) ? b : a; }

const int MOD = 1e9 + 7, inf = 1e18;
using ll = long long;
using ull = unsigned long long;
using pii = pair<int,int>;

int x[3];
int a[3];
int ans;

void backtrack(int id, int S){
    if(id > 2){
        ans = max(ans, (a[1] + x[1]) * (a[2] + x[2]) * (a[0] + x[0]) );
        return;
    }

    for(int i = 0; i <= S; i++){
        a[id] = i;
        backtrack(id + 1, S - i);
    }
}

void solve(){
    ans = 0;
    memset(a, 0, sizeof a);
    for(int i = 0; i <= 2; i++){
        cin >> x[i];
    }

    backtrack(0, 5);

    cout << ans << el;
}

signed main(){
    ios_base::sync_with_stdio(0);
    cin.tie(0);

    submit("")

    int t; cin >> t;
    while(t--) solve();

    return 0;
}
