#include<bits/stdc++.h>
using namespace std;

#define fi first
#define se second
#define int long long
#define pb push_back
#define el '\n'
#define all(x) x.begin(), x.end()
#define submit(x) if( fopen(x".inp", "r") ){ freopen(x".inp", "r", stdin); freopen(x".out", "w", stdout); }

typedef long long ll;
using pii = pair<int,int>;
const int MOD = 1e9 + 7, inf = 1e18 + 7;
using ull = unsigned long long;

const int maxn = 2e5 + 7;
pii a[maxn];

bool cmp1(pii x, pii y){
    return x.fi < y.fi;
}

void solve(){
    int n, W;
    cin >> n >> W;
    for(int i = 1; i <= n; i++) cin >> a[i].fi, a[i].se = i;
    sort(a + 1, a + 1 + n, cmp1);

    int calc = 0;
    vector<int> get;

    for(int i = n; i > 0; i--){
        if(calc + a[i].fi <= W){
            calc += a[i].fi;
            get.pb(a[i].se);
            if(calc >= (W + 1)/2) break;
        }
    }

    if(calc >= (W + 1)/2){
        reverse(all(get));
        cout << get.size() << el;
        for(int id:get) cout << id << ' ';
        cout << el;
    }
    else cout << -1 << el;
}

signed main(){
    cin.tie(0)->ios_base::sync_with_stdio(0);

    int t; cin >> t;
    while(t--) solve();

    return 0;
}


