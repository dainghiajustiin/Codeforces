}

void solve(int iTest){
    cin >> n;
    for(int i = 1; i <= n; i++){
        cin >> a[i];
    }
    a[0] = -1;
    for(int i = 1; i <= n; i++){
        upd(1, 1, n, i, i);
    }
    int lim = n, ans = 0;
    while(lim > 0){
        int v = get(1, 1, n, 1, lim);
        ans++;
        lim = v - 1;
    }
    cout << ans << el;
}

