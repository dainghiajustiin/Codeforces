const int MAXN = (int) 2e5 + 7;

int a[MAXN], st[MAXN*4], n;

///

void upd(int id, int l, int r, int pos, int val){
    if(pos < l || r < pos) return;
    if(l == r){
        st[id] = val;
        return;
    }
    int m = l + r >> 1;
    upd(id<<1, l, m, pos, val);
    upd(id<<1|1, m+1, r, pos, val);
    int it1 = st[id<<1];
    int it2 = st[id<<1|1];

    if(a[it1] > a[it2]) st[id] = it1;
    else st[id] = it2;
}

int get(int id, int l, int r, int u, int v){
    if(v < l || r < u) return 0;
    if(u <= l && r <= v) return st[id];
    int m = l + r >> 1;
    int it1 = get(id << 1, l, m, u, v);
    int it2 = get(id << 1|1, m+1, r, u, v);

    if(a[it1] > a[it2]) return it1;
    else return it2;
}

