/// code
const int maxn = (int) 1e5 + 3;
int a, b;
int f[maxn];
int p[maxn];
int n;

void solve(){
    cin >> n >> a >> b;
    for(int i = 1; i <= n; i++) cin >> f[i];

    int g = __gcd(a, b);
    for(int i = 1; i <= n; i++) f[i] %= g;
    sort(f + 1, f + 1 + n);
    int ans = f[n] - f[1];
    for(int i = 1; i < n; i++) ans = min(ans, f[i] - f[i + 1] + g);
    cout << ans << el;
}

signed main(){
    ios_base::sync_with_stdio(0);
    cin.tie(0);

