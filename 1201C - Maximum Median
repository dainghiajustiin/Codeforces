const int MAXN = (int) 2e5 + 7;

int n, k, a[MAXN];

///

void init(){

}

void solve(int iTest){
    cin >> n >> k;
    for(int i = 1; i <= n; i++) cin >> a[i];
    sort(a + 1, a + 1 + n);
    a[n+1] = MOD1;

    int ans = a[(n+1)/2];
    int posBase = (n+1)/2, pos = posBase;
    while(k > 0){
        pos = upper_bound(a + 1, a + 1 + n, a[pos]) - a - 1;
        int nxtPos = pos + 1;
        int len = (pos - posBase + 1);
        int up = k/len;

        if(a[nxtPos] > a[pos] + up){
            ans += up;
            break;
        }
        else{
            ans += a[nxtPos] - a[pos];
            k -= (a[nxtPos] - a[pos])*len;
            pos = nxtPos;
        }
    }
    cout << ans;
}

