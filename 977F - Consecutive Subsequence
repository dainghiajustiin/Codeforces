#include<bits/stdc++.h>
using namespace std;

#define fi first
#define se second
#define int long long
#define pb push_back
#define el '\n'
#define all(x) x.begin(), x.end()
#define submit(x) if( fopen(x".inp", "r") ){ freopen(x".inp", "r", stdin); freopen(x".out", "w", stdout); }

typedef long long ll;
using pii = pair<int,int>;
const int MOD = 1e9 + 7, inf = 1e18 + 7;
using ull = unsigned long long;

const int maxn = 2e5 + 7;
int n;
int a[maxn];
map<int,int> mp;
int ans = 0, isEnd = 0;

signed main(){
    cin.tie(0)->ios_base::sync_with_stdio(0);

    cin >> n;
    for(int i = 1; i <= n; i++){
        cin >> a[i];

        mp[a[i]] = max(mp[a[i]], mp[a[i] - 1] + 1);

        if(ans < mp[a[i]]){
            ans = mp[a[i]];
            isEnd = a[i];
        }
    }

    int val = isEnd - ans + 1;

    cout << ans << el;

    for(int i = 1; i <= n; i++){
        if(a[i] == val) cout << i << ' ', val++;
    }

    return 0;
}


