void solve(int iTest){
    cin >> n;
    for(int i = 1; i <= n; i++) upd(1, 1, n, i, INF);
    for(int i = 1; i <= n; i++){
        cin >> a[i];
        upd(1, 1, n, i, a[i]);
    }
    cin >> q;
    while(q-->0){
        int l, k;
        cin >> l >> k;
        if(a[l] < k) cout << -1 << ' ';
        else{
            int low = l, high = n, ans = l;
            while(low <= high){
                int mid = low + high >> 1;
                if(get(1, 1, n, l, mid) >= k){
                    ans = mid;
                    low = mid + 1;
                }
                else high = mid - 1;
            }
            cout << ans << ' ';
        }
    }
    cout << el;
}

