///
const int MAXN = (int) 2e5 + 7;
const int INF = (1 << 63) - 1;

int n, q, a[MAXN], it[MAXN * 4];
///
void upd(int id, int l, int r, int pos, int v){
    if(pos < l || r < pos) return;
    if(l == r){
        it[id] = v;
        return;
    }
    int m = l + r >> 1;
    upd(id<<1, l, m, pos, v);
    upd(id<<1|1, m+1, r, pos, v);
    it[id] = (it[id<<1] & it[id<<1|1]);
}

int get(int id, int l, int r, int u, int v){
    if(v < l || r < u) return INF;
    if(u <= l && r <= v) return it[id];
    int mid = (l + r) >> 1;
    int it1 = get(id<<1, l, mid, u, v);
    int it2 = get(id<<1|1, mid+1, r, u, v);
    return (it1 & it2);
}

void init(){

