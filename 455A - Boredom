#include<bits/stdc++.h>
using namespace std;

#define fi first
#define se second
#define int long long
#define pb push_back
#define el '\n'
#define all(x) x.begin(), x.end()
#define submit(x) if( fopen(x".inp", "r") ){ freopen(x".inp", "r", stdin); freopen(x".out", "w", stdout); }

typedef long long ll;
using pii = pair<int,int>;
const int MOD = 1e9 + 7, inf = 1e18 + 7;
using ull = unsigned long long;

const int maxn = 1e5 + 7;
int n;
int a[maxn];
int val[maxn];
int dp[maxn];
int ma = -inf;

signed main(){
    cin.tie(0)->ios_base::sync_with_stdio(0);

    cin >> n;
    for(int i = 1; i <= n; i++){
        int Ai; cin >> Ai;
        val[Ai] += Ai;
        ma = max(Ai, ma);
    }

    dp[1] = val[1];

    for(int i = 2; i <= ma + 1; i++){
        if(val[i]) dp[i] = max(dp[i - 1], val[i] + dp[i - 2]);
        else dp[i] = max(dp[i - 1], dp[i - 2]);
    }

    cout << dp[ma + 1];

    return 0;
}


