void solve(int iTest){
    cin >> n >> m;
    for(int i = 1; i <= n; i++) cin >> cat[i];
    for(int i = 1; i < n; i++){
        int u, v;
        cin >> u >> v;
        adj[u].pb(v);
        adj[v].pb(u);
    }

    DFS(1, 0, cat[1]);
    cout << ans;
}

