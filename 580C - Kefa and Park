const int maxn = (int) 1e5 + 7;

int n, m, cat[maxn], ans = 0;
vector<int> adj[maxn];

///

void DFS(int u, int pre, int cnt){
    if(cnt > m) return;
    bool isValid = true;
    for(int v:adj[u]){
        if(v == pre) continue;
        isValid = false;
        if(cat[v] > 0) DFS(v, u, cnt + 1);
        else DFS(v, u, 0);
    }
    if(isValid && u != 1) ans++;
}

