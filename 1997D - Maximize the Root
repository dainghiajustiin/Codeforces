#define fi first
#define se second
#define int long long
#define pb push_back
#define el '\n'
#define all(x) x.begin(), x.end()
#define Mp make_pair
typedef long long ll;
using pii = pair<int,int>;
const int MOD = (int) 1e9 + 7, inf = (int) 1e18 + 7;
using ull = unsigned long long;

/// code
const int maxn = (int) 2e5 + 3;
vector<int> vec[maxn];
int val[maxn];

int dfs(int u, int p){
    int tmp = inf;
    bool ok = 0;
    for(int v:vec[u]){
        if(v == p) continue;
        ok = 1;
        tmp = min(tmp, dfs(v, u));
    }

    if(u == 1){
        val[u] += tmp;
    }
    else if(ok == 1){
        if(tmp < val[u]) val[u] = tmp;
        else val[u] = (val[u] + tmp) >> 1;
    }

    return val[u];
}

void solve(){
    int n; cin >> n;
    for(int i = 1; i <= n; i++) cin >> val[i];
    for(int i = 2; i <= n; i++){
        int pi; cin >> pi;
        vec[i].pb(pi);
        vec[pi].pb(i);
    }

    int ans = dfs(1, 0);

    cout << ans << el;
    for(int i = 1; i <= n; i++) vec[i].clear();
}

signed main(){
    cin.tie(0)->ios_base::sync_with_stdio(0);

