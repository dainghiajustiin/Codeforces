#include<bits/stdc++.h>
using namespace std;

#define ll long long
#define Mp make_pair
#define fi first
#define se second
#define pb push_back
#define el '\n'
#define all(x) x.begin(), x.end()

const int MOD = (int) 1e9 + 7;
const ll inf = (ll) 1e18 + 7;
using pii = pair<int,int>;

/// code
const int maxn = (int) 2e5 + 3;
int a[maxn], n;
ll s;

bool check(ll M){
    a[n] += M;
    ll res = (s + M)/(2*n) + ((s + M)%(2*n) != 0);

    int it = lower_bound(a + 1, a + 1 + n, res) - a;
    a[n] -= M;

    return (it - 1 > n/2);
}

void solve(){
    cin >> n; s = 0;
    for(int i = 1; i <= n; i++) cin >> a[i], s += a[i];

    if(n <= 2){
        cout << -1 << el;
        return;
    }

    sort(a + 1, a + 1 + n);

    ll L = 0, R = inf;
    ll ans = inf;

    while(L <= R){
        ll M = L + R >> 1;

        if(check(M)){
            ans = M;
            R = M - 1;
        }
        else L = M + 1;
    }

    if(ans < inf) cout << ans << el;
    else cout << -1 << el;
}

signed main(){
    ios_base::sync_with_stdio(0);
    cin.tie(0);

//    #define task ""
//    freopen(task".inp", "r", stdin);
//    freopen(task".out", "w", stdout);

    int t; cin >> t;
    while(t--) solve();

    return 0;
}
