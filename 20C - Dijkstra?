using namespace std;

//#define int long long
#define fi first
#define se second
#define pb push_back
#define el '\n'
#define all(x) x.begin(), x.end()

using ll = long long;
using pii = pair<int,int>;
using ull = unsigned long long;

const int MOD1 = 1000000007;
const int MOD2 = 998244353;

mt19937_64 rd(time(0));
ll rand(ll l, ll r){
    return l + rd() % (r - l + 1);
}

///
#define pll pair<long long, long long>
const int MAXN = (int) 1e5 + 7;

ll n, m, a[MAXN], b[MAXN], w[MAXN], dp[MAXN], pre[MAXN];
vector<pll> adj[MAXN];
vector<ll> ans;

///

void dijkstra(){
    priority_queue<pll, vector<pll>, greater<pll>> pq;
    dp[1] = 0;
    pq.push({0, 1});
    while(!pq.empty()){
        ll val = pq.top().fi;
        ll u = pq.top().se;
        pq.pop();

        for(pll elm:adj[u]){
            ll s = elm.fi;
            ll v = elm.se;
            if(dp[v] > dp[u] + s){
                pre[v] = u;
                dp[v] = dp[u] + s;
                pq.push({dp[v], v});
            }
        }
    }
}

void init(){

}

void solve(int iTest){
    cin >> n >> m;
    for(int i = 1; i <= m; i++){
        cin >> a[i] >> b[i] >> w[i];
        adj[a[i]].pb({w[i], b[i]});
        adj[b[i]].pb({w[i], a[i]});
    }

    memset(dp, 0x3f, sizeof dp);
    dijkstra();

    if(dp[n] > 1ll*MOD1*MOD2){
        cout << -1;
    }
    else{
        int node = n;
        while(node != 1){
            ans.pb(node);
            node = pre[node];
        }
        ans.pb(1);
        reverse(all(ans));
        for(ll elm:ans) cout << elm << ' ';
    }
}

signed main(){
    ios_base::sync_with_stdio(0);
    cin.tie(0);

    #define task "buon"
    if(fopen(task".inp", "r")){
        freopen(task".inp", "r", stdin);
        freopen(task".out", "w", stdout);
    }

    init();

    int nTest = 1;
//    cin >> nTest;

    for(int iTest = 1; iTest <= nTest; iTest++){
        solve(iTest);
    }

    return 0;
}

