#include<bits/stdc++.h>
#define ll long long 

using namespace std;

signed main(){
    ios_base::sync_with_stdio(0);
    cin.tie(0), cout.tie(0);

    int nTest;
    cin >> nTest;

    while(nTest-->0){
        ll n; 
        bool isValid = false;
        cin >> n;

        for(ll a = 0; a <= 1234; a++){
            ll value = n - a*11;
            if(value < 0) break;
            if(value % 111 != 0) continue;
            ll b = value/111;
            if(b >= 0){
                isValid = true;
                cout << "YES\n";
                break;
            }
        }

        if(isValid) continue;

        ll value = n % 111;
        if(value % 11 != 0){
            cout << "NO\n";
        }
        else{
            cout << "YES\n";
        }
    }

    return 0;
}
