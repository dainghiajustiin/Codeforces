/// code
const int maxn = (int) 2e5 + 3;
int a[maxn], n, k;

void solve(){
    cin >> n >> k;
    int s = 0, cnt = 0;
    for(int i = 1; i <= n; i++){
        cin >> a[i];
        if(a[i] >= k) s += a[i];
        else{
            if(!a[i] && s) cnt++, s--;
        }
    }
    cout << cnt << el;
}

signed main(){
    ios_base::sync_with_stdio(0);
    cin.tie(0);

//    #define task ""
